{
  "manifest_version": 3,
  "name": "Enough YouTube for Today",
  "version": "0.0.1",
  "description": "Anti-addition extension for YouTube.",
  "icons": {
    "48": "icon.svg"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "EYTfT@klinoklaz.app",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*"],
      "js": ["content.js"]
    }
  ],
  "background": {
    "scripts": ["background.js"],
    "type": "module"
  },
  "action": {
    "default_title": "Enough YouTube for Today",
		"default_icon": "icon.svg",
    "default_popup": "popup.html"
  }
}